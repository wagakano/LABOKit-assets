        # 1. ADJUSTMENT
        page_adj = QWidget(); lay_adj = QVBoxLayout(page_adj)
        self.sl_bright = self._add_slider(lay_adj, "Brightness", -100, 100, 0)
        self.sl_contrast = self._add_slider(lay_adj, "Contrast", -100, 100, 0)
        self.sl_sat = self._add_slider(lay_adj, "Saturation", -100, 100, 0)
        lay_adj.addStretch()
        self.toolbox.addItem(page_adj, "1. Basic Adjustments")

        # 2. PATTERN
