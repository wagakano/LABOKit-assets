        btn_open = QPushButton(tr("btn_open_out", "Open Folder")); btn_open.clicked.connect(self.open_output_folder)
        out_btn_lay.addWidget(btn_change)
        out_btn_lay.addWidget(btn_open)
        left_layout.addLayout(out_btn_lay)

