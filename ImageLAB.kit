        self.update_timer.setInterval(200) # 200ms debounce
        self.update_timer.timeout.connect(self.execute_worker)
        
        self._setup_ui()

    def set_meter(self, meter):
        self.meter = meter

    def closeEvent(self, event):
        try:
            if hasattr(self, 'worker') and self.worker.isRunning():
                self.worker.quit()
                self.worker.wait()
        except:
            pass
        super().closeEvent(event)

    def __del__(self):
        try:
            if hasattr(self, 'worker') and self.worker.isRunning():
                self.worker.quit()
                self.worker.wait()
        except:
            pass

