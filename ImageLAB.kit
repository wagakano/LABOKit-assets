        self.chk_gl_rgb = QCheckBox("RGB Shift"); self.chk_gl_rgb.stateChanged.connect(self.trigger_update); lay_glitch.addWidget(self.chk_gl_rgb)
        self.chk_gl_scan = QCheckBox("Scanline Noise"); self.chk_gl_scan.stateChanged.connect(self.trigger_update); lay_glitch.addWidget(self.chk_gl_scan)
        self.sl_glitch_amt = self._add_slider(lay_glitch, "Intensity", 0, 100, 20)
        self.sl_glitch_seed = self._add_slider(lay_glitch, "Seed", 0, 100, 0)
        lay_glitch.addStretch()
