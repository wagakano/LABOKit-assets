# --- UTILS: BLENDING ---
def blend_images(bottom, top, mode, opacity):
    # Ensure dimensions match strictly
    if bottom.shape[:2] != top.shape[:2]:
        h, w = bottom.shape[:2]
        top = cv2.resize(top, (w, h), interpolation=cv2.INTER_NEAREST)

    b = bottom.astype(float) / 255.0
    t = top.astype(float) / 255.0
    
    if mode == "Normal": res = t
    elif mode == "Multiply": res = b * t
    elif mode == "Screen": res = 1 - (1 - b) * (1 - t)
    elif mode == "Overlay":
        mask = b < 0.5
        res = np.zeros_like(b)
        res[mask] = 2 * b[mask] * t[mask]
        res[~mask] = 1 - 2 * (1 - b[~mask]) * (1 - t[~mask])
    elif mode == "Add": res = b + t
    elif mode == "Difference": res = np.abs(b - t)
    else: res = t

    res = np.clip(res * 255, 0, 255).astype(np.uint8)
    return cv2.addWeighted(res, opacity, bottom, 1.0 - opacity, 0)

# --- UTILS: PATTERN GENERATOR ---
def generate_pattern(shape, type_name, obj_scale=1.0, spacing_scale=1.0):
    h, w = shape[:2]
    
    base_tile = 80
    tile_size = int(base_tile / max(1, spacing_scale))
    if tile_size < 8: tile_size = 8
    
    draw_factor = obj_scale / 5.0 
    
    tile = np.zeros((tile_size, tile_size, 3), dtype=np.uint8)
    color = (255, 255, 255) 
    thick = max(1, int(tile_size * 0.1 * draw_factor * 3))

    if type_name == "Lines (Horizontal)":
        cv2.line(tile, (0, tile_size//2), (tile_size, tile_size//2), color, thick)
    elif type_name == "Lines (Vertical)":
        cv2.line(tile, (tile_size//2, 0), (tile_size//2, tile_size), color, thick)
    elif type_name == "Lines (Diagonal)":
        cv2.line(tile, (0, 0), (tile_size, tile_size), color, thick)
    elif type_name == "Polka Dot":
        radius = int((tile_size / 2) * draw_factor)
        if radius < 1: radius = 1
        cv2.circle(tile, (tile_size//2, tile_size//2), radius, color, -1)
    elif type_name == "Chess":
        half = tile_size // 2
        tile[0:half, 0:half] = color
        tile[half:tile_size, half:tile_size] = color
    elif type_name == "Diamond":
        margin = int(tile_size * (1 - draw_factor) / 2)
        pts = np.array([[tile_size//2, margin], [tile_size-margin, tile_size//2], [tile_size//2, tile_size-margin], [margin, tile_size//2]])
        cv2.fillPoly(tile, [pts], color)
    elif type_name == "Gears":
        center = (tile_size//2, tile_size//2)
        r_outer = int((tile_size / 2) * draw_factor)
        r_inner = int(r_outer * 0.6)
        cv2.circle(tile, center, r_outer, color, -1)
        cv2.circle(tile, center, r_inner, (0,0,0), -1)

    repeat_y = (h // tile_size) + 2
    repeat_x = (w // tile_size) + 2
    full_pattern = np.tile(tile, (repeat_y, repeat_x, 1))
    
    return full_pattern[:h, :w]

# --- UTILS: ASCII RENDERER ---
def render_ascii(img_bgr, charset_name, resolution, color_mode, bg_color):
    # Charsets
    CHARSETS = {
        "Standard": "@%#*+=-:. ",
        "Matrix": "01",
        "Block": "█▓▒░ ",
        "Binary": "10 ",
        "Slant": "/\\ ",
        "Minimal": " .",
        "Code": "<>{}[]()/*",
        "Hex": "0123456789ABCDEF"
    }
    
    chars = CHARSETS.get(charset_name, CHARSETS["Standard"])
    
    h, w = img_bgr.shape[:2]
    aspect = h / w
    
    cols = max(20, resolution)
    char_w = 10 
    char_h = 18 
    char_aspect = char_h / char_w 
    
    rows = int(cols * aspect * (char_w/char_h))
    
    gray = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY)
    small_gray = cv2.resize(gray, (cols, rows), interpolation=cv2.INTER_AREA)
    
    if "Color" in color_mode:
        small_color = cv2.resize(img_bgr, (cols, rows), interpolation=cv2.INTER_AREA)
    
    out_w = cols * char_w
    out_h = rows * char_h
    
    bg_rgb = (0,0,0) if bg_color == "Black" else (255,255,255)
    fg_rgb = (255,255,255) if bg_color == "Black" else (0,0,0)
    
    if color_mode == "Matrix Green": fg_rgb = (0, 255, 0)
    elif color_mode == "Cyber Cyan": fg_rgb = (0, 255, 255)
    elif color_mode == "Hacker Red": fg_rgb = (255, 0, 0)
    
    canvas = Image.new("RGB", (out_w, out_h), bg_rgb)
    draw = ImageDraw.Draw(canvas)
    
    num_chars = len(chars)
    range_step = 255.0 / (num_chars - 1)
    
    for y in range(rows):
        for x in range(cols):
            lum = small_gray[y, x]
            char_idx = int(lum / range_step)
            
            final_idx = char_idx
            if bg_color == "Black": 
                final_idx = num_chars - 1 - char_idx 
            else:
                final_idx = char_idx
                
            final_idx = max(0, min(final_idx, num_chars - 1))
            char = chars[final_idx]
            
            pos_x = x * char_w
            pos_y = y * char_h
            
            color = fg_rgb
            if "Color" in color_mode:
                b, g, r = small_color[y, x]
                color = (r, g, b)
                
            draw.text((pos_x, pos_y), char, fill=color)
            
    return np.array(canvas)[:, :, ::-1] # RGB to BGR

# --- STANDALONE EFFECT FUNCTIONS ---

def apply_basic(img, params):
    b, c, s = params.get("b", 0), params.get("c", 0), params.get("s", 0)
    res = img
    if b != 0 or c != 0:
        alpha = (c + 100.0) / 100.0
        res = cv2.convertScaleAbs(res, alpha=alpha, beta=b)
    if s != 0:
        hsv = cv2.cvtColor(res, cv2.COLOR_BGR2HSV).astype(np.float32)
        hsv[:,:,1] *= ((s + 100.0) / 100.0)
        hsv[:,:,1] = np.clip(hsv[:,:,1], 0, 255)
        hsv = hsv.astype(np.uint8)
        res = cv2.cvtColor(hsv, cv2.COLOR_HSV2BGR)
    return res

def apply_glitch(img, params):
    amount = params.get("amount", 0)
    if amount == 0: return img
    
    res = img.copy()
    h, w = res.shape[:2]
    seed = params.get("seed", 0); np.random.seed(seed)
    
    if params.get("rgb"):
        shift = int((amount/100)*(w*0.05))
        res[:,:,2] = np.roll(res[:,:,2], shift, axis=1)
        res[:,:,0] = np.roll(res[:,:,0], -shift, axis=1)
    
    if params.get("scan"):
        noise = np.random.normal(0, amount, (h,w,3)).astype(np.uint8)
        for y in range(0, h, 4): res[y:min(y+2,h), :] = cv2.add(res[y:min(y+2,h), :], noise[y:min(y+2,h), :])
        
    return res

def apply_partial(img, params):
    if not params.get("enabled"): return img
    
    target = params.get("color") # QColor
    fuzz = params.get("fuzz", 40)
    sat_boost = params.get("sat", 0)
    
    tgt_bgr = np.uint8([[[target.blue(), target.green(), target.red()]]])
    tgt_hsv = cv2.cvtColor(tgt_bgr, cv2.COLOR_BGR2HSV)[0][0]
    hue = tgt_hsv[0]
    
    img_hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)
    l1 = np.array([max(0, hue-fuzz), 20, 20])
    u1 = np.array([min(180, hue+fuzz), 255, 255])
    mask = cv2.inRange(img_hsv, l1, u1)
    if hue < fuzz:
        mask2 = cv2.inRange(img_hsv, np.array([180-(fuzz-hue),20,20]), np.array([180,255,255]))
        mask = cv2.bitwise_or(mask, mask2)
    elif hue > 180-fuzz:
        mask2 = cv2.inRange(img_hsv, np.array([0,20,20]), np.array([hue+fuzz-180,255,255]))
        mask = cv2.bitwise_or(mask, mask2)
    
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    gray_bgr = cv2.cvtColor(gray, cv2.COLOR_GRAY2BGR)
    
    boosted = img
    if sat_boost > 0:
        bf = img_hsv.astype(np.float32)
        bf[:,:,1] *= (1.0 + sat_boost/50.0)
        bf[:,:,1] = np.clip(bf[:,:,1], 0, 255)
        boosted = cv2.cvtColor(bf.astype(np.uint8), cv2.COLOR_HSV2BGR)
    
    return cv2.add(cv2.bitwise_and(boosted, boosted, mask=mask), 
                  cv2.bitwise_and(gray_bgr, gray_bgr, mask=cv2.bitwise_not(mask)))

def apply_pattern(img, params):
    if not params.get("enabled"): return img
    
    pat_type = params.get("type"); mode = params.get("blend"); mask_mode = params.get("mask")
    scale = params.get("scale"); space = params.get("space"); opacity = params.get("opacity")
    
    h, w = img.shape[:2]
    overlay = generate_pattern((h,w,3), pat_type, scale, space)
    
    alpha_mask = None
    if mask_mode != "Whole Image":
        g = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        if mask_mode == "Dark Areas Only": alpha_mask = 255 - g
        else: alpha_mask = g
        alpha_mask = alpha_mask.astype(float) / 255.0
        alpha_mask = cv2.merge([alpha_mask, alpha_mask, alpha_mask])
    
    blended = blend_images(img, overlay, mode, 1.0)
    if alpha_mask is not None:
        f = alpha_mask * opacity
        return (img * (1.0 - f) + blended * f).astype(np.uint8)
    else:
        return cv2.addWeighted(blended, opacity, img, 1.0-opacity, 0)

# --- WORKER THREAD ---
class EffectWorker(QThread):
    finished = Signal(object) 
    
    def __init__(self):
        super().__init__()
        self.img = None
        self.params = {}
    
    def run(self):
        if self.img is None: return
        try:
            res = self.img.copy()
            
            res = apply_basic(res, self.params.get("basic", {}))
            res = apply_glitch(res, self.params.get("glitch", {}))
            res = apply_partial(res, self.params.get("partial", {}))
            res = apply_pattern(res, self.params.get("pattern", {}))

            p_ascii = self.params.get("ascii", {})
            if p_ascii.get("enabled"):
                res = render_ascii(
                    res, 
                    p_ascii.get("charset"), 
                    p_ascii.get("res"), 
                    p_ascii.get("color"), 
                    p_ascii.get("bg")
                )

            self.finished.emit(res)
        except Exception as e:
            print(f"Worker Error: {e}")
            self.finished.emit(None)

class SolidColorBtn(QPushButton):
    colorChanged = Signal(int, object) 
    def __init__(self, index, default_color, parent=None):
        super().__init__(parent)
        self.index = index
        self.current_color = QColor(default_color)
        self.setFixedWidth(40); self.setFixedHeight(25)
        self.setCursor(Qt.PointingHandCursor)
        self.clicked.connect(self.pick_color)
        self.update_look()

    def set_color_silent(self, color_hex):
        self.current_color = QColor(color_hex)
        self.update_look()

    def pick_color(self):
        self.colorChanged.emit(self.index, None) # Signal parent to start eyedropper

    def set_color(self, color):
        self.current_color = color
        self.update_look()

    def update_look(self):
        self.setStyleSheet(f"""
            QPushButton {{
                background-color: {self.current_color.name()};
                border: 1px solid #666;
                border-radius: 0px; 
            }}
            QPushButton:hover {{ border: 2px solid #fff; }}
        """)

