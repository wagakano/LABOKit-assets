        self.chk_part = QCheckBox("Enable Partial Color"); self.chk_part.stateChanged.connect(self.trigger_update); lay_part.addWidget(self.chk_part)
        h_pcol = QHBoxLayout(); h_pcol.addWidget(QLabel("Keep Color:"))
        self.btn_part_col = SolidColorBtn(99, "#ff0000"); self.btn_part_col.colorChanged.connect(self.open_color_picker)
        h_pcol.addWidget(self.btn_part_col); lay_part.addLayout(h_pcol)
        self.sl_part_fuzz = self._add_slider(lay_part, "Color Range", 1, 100, 40)
        self.sl_part_sat = self._add_slider(lay_part, "Saturation Boost", 0, 100, 20) 
        lay_part.addStretch()
        self.toolbox.addItem(page_part, "4. Partial Color")

        # 5. ASCII LAB
        page_ascii = QWidget(); lay_ascii = QVBoxLayout(page_ascii)
        self.chk_ascii = QCheckBox("Enable ASCII Lab"); self.chk_ascii.stateChanged.connect(self.trigger_update)
        lay_ascii.addWidget(self.chk_ascii)
        
        self.cb_ascii_char = QComboBox(); self.cb_ascii_char.addItems(["Standard", "Matrix", "Block", "Binary", "Slant", "Minimal", "Code", "Hex"])
        self.cb_ascii_char.currentTextChanged.connect(self.trigger_update)
        lay_ascii.addWidget(QLabel("Charset:")); lay_ascii.addWidget(self.cb_ascii_char)
        
        self.sl_ascii_res = self._add_slider(lay_ascii, "Resolution (Cols)", 20, 200, 80)
        self.sl_ascii_res.valueChanged.connect(self.force_fit_next)
        
        self.cb_ascii_mode = QComboBox(); self.cb_ascii_mode.addItems(["Color", "Grayscale", "Matrix Green", "Cyber Cyan", "Hacker Red"])
        self.cb_ascii_mode.currentTextChanged.connect(self.trigger_update)
        lay_ascii.addWidget(QLabel("Color Mode:")); lay_ascii.addWidget(self.cb_ascii_mode)
        
        self.cb_ascii_bg = QComboBox(); self.cb_ascii_bg.addItems(["Black", "White"])
        self.cb_ascii_bg.currentTextChanged.connect(self.trigger_update)
        lay_ascii.addWidget(QLabel("Background:")); lay_ascii.addWidget(self.cb_ascii_bg)
        
        lay_ascii.addStretch()
        self.toolbox.addItem(page_ascii, "5. ASCII Lab")

        left_layout.addWidget(self.toolbox)
        
        btn_sel = QPushButton("Process Selected"); btn_sel.clicked.connect(self.process_selected)
        btn_all = QPushButton("Process All"); btn_all.clicked.connect(self.process_all)
        left_layout.addWidget(btn_sel)
        left_layout.addWidget(btn_all)

    def _add_slider(self, layout, label, min_val, max_val, default):
        # Styled Layout for Label: "Title" ........ [ Value ]
        row = QHBoxLayout()
        l = QLabel(label)
        v = QLabel(str(default))
        v.setProperty("role", "value") # For styling
        row.addWidget(l)
        row.addStretch()
        row.addWidget(v)
        layout.addLayout(row)
        
        s = QSlider(Qt.Horizontal); s.setRange(min_val, max_val); s.setValue(default)
        layout.addWidget(s)
        s.valueChanged.connect(lambda val, lbl=v: lbl.setText(str(val)))
        s.valueChanged.connect(self.trigger_update) 
        return s

    # --- LOGIC ---
    def open_color_picker(self, idx, _):
        color = QColorDialog.getColor(self.btn_part_col.current_color, self, "Select Color")
        if color.isValid():
            self.btn_part_col.set_color(color)
            if self.meter: self.meter.set_message(f"Selected Color: {color.name()}")
            self.trigger_update()
            if self.meter: QTimer.singleShot(1500, lambda: self.meter.set_message(None))

    def force_fit_next(self):
        # If ASCII res changed, next display should fit
        self.pending_fit = True

    def trigger_update(self):
        # Update meter immediately
        if self.meter: self.meter.set_message("Processing...")
        self.update_timer.start() 

    def execute_worker(self):
        if self.img_preview is None: return
        if self.worker.isRunning():
            self.worker.quit()
            self.worker.wait()
        
        # Gather Params
        params = {
            "basic": {
                "b": self.sl_bright.value(),
                "c": self.sl_contrast.value(),
                "s": self.sl_sat.value()
            },
            "glitch": {
                "amount": self.sl_glitch_amt.value(),
                "seed": self.sl_glitch_seed.value(),
                "rgb": self.chk_gl_rgb.isChecked(),
                "scan": self.chk_gl_scan.isChecked()
            },
            "partial": {
                "enabled": self.chk_part.isChecked(),
                "color": self.btn_part_col.current_color,
                "fuzz": self.sl_part_fuzz.value(),
                "sat": self.sl_part_sat.value()
            },
            "pattern": {
                "enabled": self.chk_pat.isChecked(),
                "type": self.cb_pattern.currentText(),
                "mask": self.cb_pat_mask.currentText(),
                "blend": self.cb_blend.currentText(),
                "scale": self.sl_pat_scale.value(),
                "space": self.sl_pat_spacing.value(),
                "opacity": self.sl_pat_opacity.value() / 100.0
            },
            "ascii": {
                "enabled": self.chk_ascii.isChecked(),
                "charset": self.cb_ascii_char.currentText(),
                "res": self.sl_ascii_res.value(),
                "color": self.cb_ascii_mode.currentText(),
                "bg": self.cb_ascii_bg.currentText()
            }
        }
        
        self.worker.img = self.original_preview 
        self.worker.params = params
        self.worker.start()

    def on_worker_finished(self, result_img):
        if result_img is not None:
            fit = getattr(self, 'pending_fit', False)
            self._display_image(result_img, fit=fit)
            self.pending_fit = False # Reset
            if self.meter: self.meter.set_message(None)
        else:
            if self.meter: self.meter.set_message("Error")

    def clear_image(self):
        self.img_full = None; self.img_preview = None; self.original_preview = None; self.active_file_path = None
        self.preview_widget.set_image_pixmaps(None, None)

    def on_file_selected_item(self, item, prev=None):
        if not item:
            self.clear_image()
            return
        real_path = item.data(Qt.UserRole)
        if real_path and str(real_path) != str(self.active_file_path):
            self.active_file_path = real_path
            try:
                pil_img = Image.open(real_path).convert("RGB")
                img = np.array(pil_img)
                img = cv2.cvtColor(img, cv2.COLOR_RGB2BGR)
                self.img_full = img
                
                h, w = img.shape[:2]
                max_dim = 1280 
                scale = max_dim / w if w > max_dim else 1.0
                if scale < 1.0:
                    new_w, new_h = int(w*scale), int(h*scale)
                    self.original_preview = cv2.resize(img, (new_w, new_h), interpolation=cv2.INTER_AREA)
                else:
                    self.original_preview = img.copy()
                
                self.img_preview = self.original_preview.copy()
                self._display_image(self.img_preview, is_initial=True)
                
                self.trigger_update()
            except Exception as e:
                QMessageBox.critical(self, "Error", f"Failed to load image:\n{e}")

    def add_dropped_files(self, files):
        self.add_files(files)

    def add_images(self):
        files, _ = QFileDialog.getOpenFileNames(self, "Select Images", "", "Images (*.jpg *.png *.webp *.bmp)")
        if not files: return
        self.add_files([Path(f) for f in files])

    def add_files(self, paths):
        for p in paths:
            item = QListWidgetItem(p.name)
            item.setData(Qt.UserRole, p)
            self.file_list.addItem(item)
            self.image_paths.append(p)
            self.path_map[p] = p
        
        if self.file_list.count() > 0 and self.file_list.currentRow() < 0:
            self.file_list.setCurrentRow(0)

    def clear_list(self):
        self.clear_image()
        self.image_paths.clear()
        self.file_list.clear()
        self.path_map.clear()

    def change_output_folder(self):
        d = QFileDialog.getExistingDirectory(self, "Select Output Folder")
        if d:
            self.output_dir = Path(d)
            self.output_label.setText(f"{self.output_dir}")
            QMessageBox.information(self, "Success", f"Output folder changed to:\n{self.output_dir}")

    def open_output_folder(self):
        d = self.output_dir
        if not d and self.image_paths:
            d = self.path_map.get(self.image_paths[0], self.image_paths[0]).parent
        if d and d.exists():
            import os
            os.startfile(str(d))
        else:
            QMessageBox.information(self, "Info", "Output folder does not exist yet. Process an image first.")

    def ensure_output_dir(self, sample):
        if not self.output_dir:
            original_source = self.path_map.get(sample, sample)
            self.output_dir = original_source.parent / "LABOKit_ImageLAB"
            self.output_dir.mkdir(exist_ok=True)
            self.output_label.setText(f"{self.output_dir}")
        return self.output_dir

    def process_selected(self):
        sel = self.file_list.selectedItems()
        if sel:
            targets = [i.data(Qt.UserRole) for i in sel]
            self._run_process(targets)

    def process_all(self):
        targets = [self.file_list.item(i).data(Qt.UserRole) for i in range(self.file_list.count())]
        self._run_process(targets)

    def _run_process(self, paths):
        if not paths: return
        out = self.ensure_output_dir(paths[0])
        
        self.dlg = QProgressDialog("Initializing...", "Cancel", 0, len(paths), self)
        self.dlg.setWindowModality(Qt.ApplicationModal)
        self.dlg.show()
        
        params = {
            "basic": {
                "b": self.sl_bright.value(),
                "c": self.sl_contrast.value(),
                "s": self.sl_sat.value()
            },
            "glitch": {
                "amount": self.sl_glitch_amt.value(),
                "seed": self.sl_glitch_seed.value(),
                "rgb": self.chk_gl_rgb.isChecked(),
                "scan": self.chk_gl_scan.isChecked()
            },
            "partial": {
                "enabled": self.chk_part.isChecked(),
                "color": self.btn_part_col.current_color,
                "fuzz": self.sl_part_fuzz.value(),
                "sat": self.sl_part_sat.value()
            },
            "pattern": {
                "enabled": self.chk_pat.isChecked(),
                "type": self.cb_pattern.currentText(),
                "mask": self.cb_pat_mask.currentText(),
                "blend": self.cb_blend.currentText(),
                "scale": self.sl_pat_scale.value(),
                "space": self.sl_pat_spacing.value(),
                "opacity": self.sl_pat_opacity.value() / 100.0
            },
            "ascii": {
                "enabled": self.chk_ascii.isChecked(),
                "charset": self.cb_ascii_char.currentText(),
                "res": self.sl_ascii_res.value(),
                "color": self.cb_ascii_mode.currentText(),
                "bg": self.cb_ascii_bg.currentText()
            }
        }
        
        self.batch_worker = BatchImageLabWorker(paths, out, params)
        self.batch_worker.progress.connect(self.on_batch_progress)
        self.batch_worker.finished.connect(self.on_batch_finished)
        self.dlg.canceled.connect(self.batch_worker.stop)
        self.batch_worker.start()

    def on_batch_progress(self, idx, msg):
        self.dlg.setLabelText(msg)
        self.dlg.setValue(idx)
        if self.meter: self.meter.set_message(msg)

    def on_batch_finished(self, count):
        self.dlg.close()
        if self.meter: self.meter.set_message(None)
        QMessageBox.information(self, "Done", f"Processed {count} files.\nSaved to: {self.output_dir}")

    def _display_image(self, cv_img, is_initial=False, fit=False):
        rgb = cv2.cvtColor(cv_img, cv2.COLOR_BGR2RGB)
        h, w, ch = rgb.shape
        bytes_per_line = ch * w
        qimg = QImage(rgb.data, w, h, bytes_per_line, QImage.Format_RGB888).copy()
        pix = QPixmap.fromImage(qimg)
        
        if is_initial:
            self.preview_widget.set_image_pixmaps(None, pix)
        else:
            # If fit is True, we don't preserve zoom (pass preserve_zoom=False)
            self.preview_widget.set_image_pixmaps(None, pix, preserve_zoom=not fit)

class BatchImageLabWorker(QThread):
    progress = Signal(int, str)
    finished = Signal(int)
    
    def __init__(self, paths, out_dir, params, parent=None):
        super().__init__(parent)
        self.paths = paths
        self.out_dir = out_dir
        self.params = params
        self._is_running = True

    def run(self):
        cnt = 0
        for i, p in enumerate(self.paths):
            if not self._is_running:
                break
            self.progress.emit(i, f"Processing {p.name}...")
            
            try:
                # Load full image
                pil_img = Image.open(p).convert("RGB")
                img = np.array(pil_img)
                img = cv2.cvtColor(img, cv2.COLOR_RGB2BGR)
                
                # Apply effects using standalone functions
                res = img.copy()
                res = apply_basic(res, self.params.get("basic", {}))
                res = apply_glitch(res, self.params.get("glitch", {}))
                res = apply_partial(res, self.params.get("partial", {}))
                res = apply_pattern(res, self.params.get("pattern", {}))
                
                p_ascii = self.params.get("ascii", {})
                if p_ascii.get("enabled"):
                    res = render_ascii(
                        res, 
                        p_ascii.get("charset"), 
                        p_ascii.get("res"), 
                        p_ascii.get("color"), 
                        p_ascii.get("bg")
                    )
                
                # Save image
                out_name = f"{p.stem}_imagelab.png"
                save_path = self.out_dir / out_name
                is_success, buf = cv2.imencode(".png", res)
                if is_success:
                    buf.tofile(str(save_path))
                
                cnt += 1
            except Exception as e:
                print(f"Error processing {p.name}: {e}")
                
        self.finished.emit(cnt)

    def stop(self):
        self._is_running = False

def create_tab(parent=None):
    return ImageLabTab(parent)
