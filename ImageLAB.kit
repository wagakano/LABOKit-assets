        self.cb_pattern.currentTextChanged.connect(self.trigger_update); lay_pat.addWidget(QLabel("Pattern Type:")); lay_pat.addWidget(self.cb_pattern)
        self.cb_pat_mask = QComboBox(); self.cb_pat_mask.addItems(["Whole Image", "Dark Areas Only", "Light Areas Only"])
        self.cb_pat_mask.currentTextChanged.connect(self.trigger_update); lay_pat.addWidget(QLabel("Apply To:")); lay_pat.addWidget(self.cb_pat_mask)
        self.cb_blend = QComboBox(); self.cb_blend.addItems(["Overlay", "Multiply", "Screen", "Add", "Difference", "Normal"])
        self.cb_blend.currentTextChanged.connect(self.trigger_update); lay_pat.addWidget(QLabel("Blend Mode:")); lay_pat.addWidget(self.cb_blend)
        self.sl_pat_scale = self._add_slider(lay_pat, "Scale", 1, 10, 3)
        self.sl_pat_spacing = self._add_slider(lay_pat, "Density", 1, 10, 2) 
        self.sl_pat_opacity = self._add_slider(lay_pat, "Opacity", 0, 100, 50)
        lay_pat.addStretch()
        self.toolbox.addItem(page_pat, "2. Pattern Overlay")

        # 3. GLITCH
