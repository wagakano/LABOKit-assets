    # --- LOGIC ---

    def change_output_folder(self):
        d = QFileDialog.getExistingDirectory(self, "Select Output Folder")
        if d:
            self.output_dir = Path(d)
            self.output_label.setText(f"{self.output_dir}")
            QMessageBox.information(self, "Success", f"Output folder changed to:\n{self.output_dir}")

    def open_output_folder(self):
        d = self.output_dir
        if not d and self.image_paths:
            d = self.path_map.get(self.image_paths[0], self.image_paths[0]).parent
        if d and d.exists():
            os.startfile(str(d))
        else:
            QMessageBox.information(self, "Info", "Output folder does not exist yet. Process an image first.")

    def on_palette_change(self, text):
        self.btn_pick_color.setVisible("Custom" in text)
        self.trigger_update()

    def pick_custom_colors(self):
        c1 = QColorDialog.getColor(QColor(*self.custom_col_1), self, "Pick Foreground")
        if c1.isValid(): 
            self.custom_col_1 = [c1.red(), c1.green(), c1.blue()]
            c2 = QColorDialog.getColor(QColor(*self.custom_col_2), self, "Pick Background")
            if c2.isValid():
                self.custom_col_2 = [c2.red(), c2.green(), c2.blue()]
                self.trigger_update()

    def update_scale_label(self, val): self.lbl_scale.setText(f"{val}x")
    def update_bloom_label(self, val): self.lbl_bloom_int.setText(str(val))
    def update_rad_label(self, val): self.lbl_bloom_rad.setText(str(val))

    def add_dropped_files(self, files):
        self.add_files(files)

    def add_images(self):
        files, _ = QFileDialog.getOpenFileNames(self, "Select Images", "", IMAGE_FILTER)
        if not files: return
        self.add_files([Path(f) for f in files])
    
    def add_gif(self):
        files, _ = QFileDialog.getOpenFileNames(self, "Select GIF", "", GIF_FILTER)
        if not files: return
        self.add_files([Path(f) for f in files])

    def add_files(self, paths):
        # 1. SCAN & ASK (Only for non-GIFs)
        large_files = []
        for p in paths:
            if p.suffix.lower() == ".gif": continue 
            try:
                with Image.open(p) as tmp:
                    tmp = ImageOps.exif_transpose(tmp) 
                    if tmp.width > 1500 or tmp.height > 1500:
                        large_files.append(p)
            except: pass
            
        do_downscale = False
        if large_files:
            ans = QMessageBox.question(self, "Resolution Check", 
                f"{len(large_files)} images are larger than 1500px.\n"
                "Downscaling is recommended for better effect.\n\n"
                "Auto-downscale to 1500px width?", 
                QMessageBox.Yes | QMessageBox.No)
            if ans == QMessageBox.Yes: do_downscale = True

        prog = None
        if do_downscale:
            prog = QProgressDialog("Caching...", None, 0, len(paths), self)
            prog.setWindowModality(Qt.ApplicationModal); prog.show()

        for i, p in enumerate(paths):
            item = QListWidgetItem(p.name)
            
            if p.suffix.lower() == ".gif":
                item.setData(Qt.UserRole, p)
                self.file_list.addItem(item)
                self.image_paths.append(p)
                self.path_map[p] = p
                continue

            if do_downscale and p in large_files:
                try:
                    with Image.open(p) as img:
                        img = ImageOps.exif_transpose(img)
                        ratio = 1500 / float(img.width)
                        new_h = int(img.height * ratio)
                        img = img.resize((1500, new_h), Image.Resampling.LANCZOS)
                        
                        cache_path = CACHE_DIR / f"{p.stem}_cached_1500px.png"
                        img.save(cache_path)
                        
                        item.setText(f"{p.name} (Cached)")
                        item.setData(Qt.UserRole, cache_path) 
                        self.file_list.addItem(item)
                        self.image_paths.append(cache_path)
                        self.path_map[cache_path] = p
                except Exception as e: print(e)
            else:
                item.setData(Qt.UserRole, p)
                self.file_list.addItem(item)
                self.image_paths.append(p)
                self.path_map[p] = p
            
            if prog: prog.setValue(i+1)
        
        if prog: prog.close()
        if self.file_list.count() > 0 and self.file_list.currentRow() < 0:
            self.file_list.setCurrentRow(0)

    def clear_list(self):
        self.close_image()
        self.image_paths.clear(); self.file_list.clear(); self.path_map.clear()
        try:
            for f in CACHE_DIR.glob("*"):
                try: os.remove(f)
                except: pass
        except: pass

    def close_image(self):
        """Forces the image preview to close/unload."""
        self.preview_proxy_img = None
        self.loaded_proxy_path = ""
        self.current_preview_path = None
        self.preview_widget.set_images(None, None) 

    def on_animate_changed(self, state):
        enabled = self.chk_animate.isChecked()
        self.anim_mode_combo.setEnabled(enabled)
        self.anim_frames_slider.setEnabled(enabled)
        self.anim_speed_slider.setEnabled(enabled)
        if self.current_preview_path:
            is_gif = self.current_preview_path.suffix.lower() == ".gif"

    def on_file_selected(self, item):
        if not item: 
            self.close_image()
            return
        real_path = item.data(Qt.UserRole)
        is_gif = real_path.suffix.lower() == ".gif"
        
        if real_path and str(real_path) != self.loaded_proxy_path:
            self.current_preview_path = real_path
            try:
                # Use shared widget logic for GIF playback if possible
                self.preview_widget.set_images(None, real_path) 
                
                # But we also need a proxy for processing preview
                temp_img = Image.open(real_path)
                
                if getattr(temp_img, "is_animated", False):
                    temp_img.seek(0)
                
                temp_img = ImageOps.exif_transpose(temp_img)
                full_img = temp_img.convert("RGBA")
                
                # Create a proxy for display
                MAX_P = PREVIEW_MAX_SIZE
                w, h = full_img.size
                if max(w, h) > MAX_P:
                    ratio = min(MAX_P/w, MAX_P/h)
                    self.preview_proxy_img = full_img.resize((int(w*ratio), int(h*ratio)), Image.Resampling.BOX)
                else:
                    self.preview_proxy_img = full_img.copy()
                
                self.loaded_proxy_path = str(real_path)
                
                self.trigger_update()
                
            except Exception as e:
                print(f"Load Error: {e}")

    def trigger_update(self):
        self.debounce_timer.start()
        if self.preview_proxy_img is not None and self.meter:
            self.meter.set_message("Processing...")


    def start_preview_worker(self):
        if not self.preview_proxy_img: return
        
        is_animating = self.chk_animate.isChecked() or (self.current_preview_path and self.current_preview_path.suffix.lower() == ".gif")
        
        if is_animating:
            # Live Animated Preview
            if hasattr(self, "live_gif_worker") and self.live_gif_worker.isRunning():
                self.live_gif_worker.stop()
                self.live_gif_worker.wait() # wait for it to exit safely
                
            timestamp = int(time.time() * 1000)
            temp_out = CACHE_DIR / f"preview_gif_{timestamp}"
            temp_out.mkdir(parents=True, exist_ok=True)
            
            self.live_gif_worker = BatchDitherWorker(
                [self.current_preview_path], 
                temp_out, 
                self._get_params(), 
                [self.custom_col_1, self.custom_col_2]
            )
            # Use same logic as gif preview finish
            self.live_gif_worker.finished.connect(lambda c: self.on_live_gif_preview_finished(temp_out))
            self.live_gif_worker.start()
        else:
            # Static Preview
            params = self._get_params()
            self.preview_worker.set_data(self.preview_proxy_img, params, [self.custom_col_1, self.custom_col_2])
            self.preview_worker.start()
    
    def _get_params(self):
        return {
            "scale": self.scale_slider.value(),
            "palette": self.palette_combo.currentText(),
            "mode": self.mode_combo.currentText(),
            "bloom_intensity": self.bloom_int_slider.value(),
            "bloom_radius": self.bloom_rad_slider.value(),
            "brightness": self.br_slider.value(),
            "contrast": self.ct_slider.value() / 10.0,
            "softness": self.soft_slider.value(),
            "noise": self.noise_slider.value(),
            "bleed": self.bleed_slider.value() / 100.0,
            "animate_static": self.chk_animate.isChecked(),
            "anim_mode": self.anim_mode_combo.currentText(),
            "anim_frames": self.anim_frames_slider.value(),
            "anim_speed": self.anim_speed_slider.value()
        }

    def on_preview_ready(self, pix_res):
        # Safety Check: If preview was cleared while worker was running, ignore result
        if not self.current_preview_path or not self.preview_proxy_img:
            if self.meter: self.meter.set_message(None)
            return

        if pix_res:
            self.preview_widget.set_result_pixmap(pix_res)
            
        if self.meter: self.meter.set_message(None)

    def ensure_output_dir(self, sample):
        if not self.output_dir:
            original_source = self.path_map.get(sample, sample)
            self.output_dir = original_source.parent / "LABOKit_Dither"
            self.output_dir.mkdir(exist_ok=True)
            self.output_label.setText(f"{self.output_dir}")
        return self.output_dir

    def process_selected(self):
        sel = self.file_list.selectedItems()
        if sel:
            targets = [i.data(Qt.UserRole) for i in sel]
            self._run_process(targets)

    def process_all(self):
        targets = [self.file_list.item(i).data(Qt.UserRole) for i in range(self.file_list.count())]
        self._run_process(targets)


    def on_live_gif_preview_finished(self, temp_out):
        generated = list(temp_out.glob("*.gif"))
        if generated and self.current_preview_path:
            self.preview_widget.set_images(None, generated[0])
            
        if self.meter: self.meter.set_message(None)

    def _run_process(self, paths):
        if not paths: return
        out = self.ensure_output_dir(paths[0])
        
        self.dlg = QProgressDialog(tr("msg_done", "Initializing..."), "Cancel", 0, len(paths), self)
        self.dlg.setWindowModality(Qt.ApplicationModal)
        self.dlg.show()
        
        self.batch_worker = BatchDitherWorker(
            paths, 
            out, 
            self._get_params(), 
            [self.custom_col_1, self.custom_col_2]
        )
        self.batch_worker.progress.connect(self.on_batch_progress)
        self.batch_worker.finished.connect(self.on_batch_finished)
        self.dlg.canceled.connect(self.batch_worker.stop)
        self.batch_worker.start()

    def on_batch_progress(self, idx, msg):
        self.dlg.setLabelText(msg)
        self.dlg.setValue(idx)
        if self.meter: self.meter.set_message(msg)

    def on_batch_finished(self, count):
        self.dlg.close()
        if self.meter: self.meter.set_message(None)
        QMessageBox.information(self, tr("msg_done", "Done"), f"Processed {count} files.\nSaved to: {self.output_dir}")

def create_tab(parent=None): return DitheringTab(parent)
