# --- MATRICES ---
BAYER_4x4 = [[0,32,8,40],[48,16,56,24],[12,44,4,36],[60,28,52,20]]
LINES_DIAG = [[10,20,30,40],[40,10,20,30],[30,40,10,20],[20,30,40,10]]
LINES_HORZ = [[0, 0, 0, 0],[32, 32, 32, 32],[48, 48, 48, 48],[16, 16, 16, 16]]
LINES_VERT = [[0, 32, 48, 16],[0, 32, 48, 16],[0, 32, 48, 16],[0, 32, 48, 16]]

# --- ERROR DIFFUSION KERNELS ---
KERNELS = {
    "Atkinson": {
        "offsets": [(1, 0, 1), (2, 0, 1), (-1, 1, 1), (0, 1, 1), (1, 1, 1), (0, 2, 1)],
        "divisor": 8 
    },
    "Stucki": {
        "offsets": [
            (1, 0, 8), (2, 0, 4), 
            (-2, 1, 2), (-1, 1, 4), (0, 1, 8), (1, 1, 4), (2, 1, 2),
            (-2, 2, 1), (-1, 2, 2), (0, 2, 4), (1, 2, 2), (2, 2, 1)
        ],
        "divisor": 42
    },
    "Sierra": {
        "offsets": [
            (1, 0, 5), (2, 0, 3),
            (-2, 1, 2), (-1, 1, 4), (0, 1, 5), (1, 1, 4), (2, 1, 2),
            (-1, 2, 2), (0, 2, 3), (1, 2, 2)
        ],
        "divisor": 32
    },
    "Burkes": {
        "offsets": [
            (1, 0, 8), (2, 0, 4),
            (-2, 1, 2), (-1, 1, 4), (0, 1, 8), (1, 1, 4), (2, 1, 2)
        ],
        "divisor": 32
    }
}

# --- SHARED PROCESSING LOGIC ---
def process_dithering(img_pil, params, custom_cols):
    frame_idx = params.get("frame_idx", 0)
    anim_mode = params.get("anim_mode", "Scrolling Pattern")

    # 1. Resize Down
    original_w, original_h = img_pil.size
    scale_factor = params.get("scale", 1)
    target_w, target_h = original_w, original_h
    
    if scale_factor > 1:
        target_w = max(1, target_w // scale_factor)
        target_h = max(1, target_h // scale_factor)
        img_pil = img_pil.resize((target_w, target_h), Image.Resampling.LANCZOS)

    # 2. Pre-Process
    bright = params.get("brightness", 0)
    contrast = params.get("contrast", 1.0)
    softness = params.get("softness", 0)
    noise_amt = params.get("noise", 0)
    
    if bright != 0:
        factor = 1.0 + (bright / 100.0)
        img_pil = ImageEnhance.Brightness(img_pil).enhance(factor)
        
    if contrast != 1.0:
        img_pil = ImageEnhance.Contrast(img_pil).enhance(contrast)
        
    if softness > 0:
        img_pil = img_pil.filter(ImageFilter.GaussianBlur(softness / 10.0))
        
    # If Jitter/Noise animation is selected, add subtle noise per frame
    if frame_idx > 0 and anim_mode == "Jitter / Noise":
        rng = random.Random(frame_idx)
        w, h = img_pil.size
        noise_bytes = bytes(rng.randint(0, 255) for _ in range(w * h))
        noise_img = Image.frombytes("L", (w, h), noise_bytes).convert("RGB")
        if img_pil.mode != 'RGB': img_pil = img_pil.convert('RGB')
        img_pil = Image.blend(img_pil, noise_img, 0.05)
        
    if noise_amt > 0:
        w, h = img_pil.size
        noise = Image.effect_noise((w, h), noise_amt).convert("RGB")
        if img_pil.mode != 'RGB': img_pil = img_pil.convert('RGB')
        img_pil = ImageChops.screen(img_pil, noise) 

    # 3. Dither
    palette_name = params.get("palette", "1-Bit (B&W)")
    if "Custom" in palette_name and custom_cols:
        rgb = custom_cols[0] + custom_cols[1]
    else:
        rgb = PALETTES.get(palette_name, PALETTES["1-Bit (B&W)"])
        
    full_pal = rgb + [0] * (768 - len(rgb))
    p_img = Image.new('P', (1, 1)); p_img.putpalette(full_pal)
    
    img_gray = img_pil.convert("L")
    mode = params.get("mode", "Floyd")

    if "Floyd" in mode:
        working_img = img_pil.convert("RGB")
        dithered = working_img.quantize(palette=p_img, dither=Image.Dither.FLOYDSTEINBERG)
    elif mode in KERNELS:
        bleed = params.get("bleed", 1.0)
        dithered = _error_diffusion(img_gray, p_img, KERNELS[mode], bleed)
    elif "Bayer" in mode: dithered = _map_pattern(img_gray, p_img, "bayer4", frame_idx, anim_mode)
    elif "Lines (Diagonal)" in mode: dithered = _map_pattern(img_gray, p_img, "lines_d", frame_idx, anim_mode)
    elif "Lines (Horizontal)" in mode: dithered = _map_pattern(img_gray, p_img, "lines_h", frame_idx, anim_mode)
    elif "Lines (Vertical)" in mode: dithered = _map_pattern(img_gray, p_img, "lines_v", frame_idx, anim_mode)
    elif "Halftone" in mode: dithered = _map_pattern(img_gray, p_img, "halftone", frame_idx, anim_mode)
    elif "Noise" in mode: dithered = _map_pattern(img_gray, p_img, "noise", frame_idx, anim_mode)
    else:
        working_img = img_pil.convert("RGB")
        dithered = working_img.quantize(palette=p_img, dither=Image.Dither.NONE)

    # 4. Bloom (Post-Dither)
    bloom_int = params.get("bloom_intensity", 0)
    bloom_rad = params.get("bloom_radius", 0)
    
    result = dithered.convert("RGB") 
    
    if bloom_int > 0:
        glow = result.filter(ImageFilter.GaussianBlur(bloom_rad))
        glow = ImageEnhance.Brightness(glow).enhance(bloom_int / 50.0)
        result = ImageChops.add(result, glow)

    # 5. Restore Size
    if result.size != (original_w, original_h):
            result = result.resize((original_w, original_h), Image.Resampling.NEAREST)

    return result

def _map_pattern(gray, pal_img, p_type, frame_idx=0, anim_mode="Scrolling Pattern"):
    w, h = gray.size
    pat = Image.new("L", (w, h))
    data = []
    
    offset_x = 0
    offset_y = 0
    if frame_idx > 0:
        if anim_mode == "Scrolling Pattern":
            offset_x = frame_idx
            offset_y = frame_idx
        elif anim_mode == "Jitter / Noise":
            rng = random.Random(frame_idx)
            offset_x = rng.randint(0, 16)
            offset_y = rng.randint(0, 16)
            
    def build_pattern(matrix, scale=4):
        rows = len(matrix)
        cols = len(matrix[0])
        scaled = [[v * scale for v in r] for r in matrix]
        for y in range(h):
            r_idx = (y + offset_y) % rows
            row = scaled[r_idx]
            shifted = [row[(x + offset_x) % cols] for x in range(cols)]
            repeats = (w // cols) + 1
            data.extend((shifted * repeats)[:w])

    if p_type == "bayer4": build_pattern(BAYER_4x4)
    elif p_type == "lines_d": build_pattern(LINES_DIAG)
    elif p_type == "lines_h": build_pattern(LINES_HORZ)
    elif p_type == "lines_v": build_pattern(LINES_VERT)
    elif p_type == "halftone":
        dots = [[0, 100, 100, 0], [100, 255, 255, 100], [100, 255, 255, 100], [0, 100, 100, 0]]
        build_pattern(dots, 1)
    elif p_type == "noise":
        if frame_idx > 0:
            rng = random.Random(frame_idx)
            noise_bytes = bytes(rng.randint(0, 255) for _ in range(w * h))
            noise = Image.frombytes("L", (w, h), noise_bytes)
        else:
            noise = Image.effect_noise((w, h), 40)
        return ImageChops.add(gray, ImageChops.subtract(noise, Image.new("L", (w,h), 128))).convert("RGB").quantize(palette=pal_img, dither=Image.Dither.NONE)
    
    if data: pat.putdata(data)
    dithered = ImageChops.add(gray, ImageChops.subtract(pat, Image.new("L", (w,h), 128)))
    return dithered.convert("RGB").quantize(palette=pal_img, dither=Image.Dither.NONE)

def _error_diffusion(img_gray, pal_img, kernel_info, bleed):
    offsets = kernel_info["offsets"]
    divisor = float(kernel_info["divisor"])
    
    pal_bytes = pal_img.getpalette()
    pal_lums = []
    for i in range(0, len(pal_bytes), 3):
        if i+2 < len(pal_bytes):
            r, g, b = pal_bytes[i], pal_bytes[i+1], pal_bytes[i+2]
            lum = int(0.299*r + 0.587*g + 0.114*b)
            if lum not in pal_lums:
                pal_lums.append(lum)
                
    # Pre-compute lookup table for nearest luminance
    lookup = [min(pal_lums, key=lambda l: abs(l - val)) for val in range(256)]
    
    w, h = img_gray.size
    pixels = img_gray.load() 
    
    # Pre-allocate 1D flat buffer for faster indexing
    buffer = [0.0] * (w * h)
    for y in range(h):
        idx = y * w
        for x in range(w):
            buffer[idx + x] = pixels[x, y]
            
    # Process
    for y in range(h):
        idx = y * w
        for x in range(w):
            old_val = buffer[idx + x]
            
            # Clamp value
            if old_val < 0: clamped_val = 0
            elif old_val > 255: clamped_val = 255
            else: clamped_val = int(old_val)
                
            nearest_lum = lookup[clamped_val]
            pixels[x, y] = nearest_lum
            
            err = (old_val - nearest_lum) * bleed
            if err == 0:
                continue
                
            for dx, dy, weight in offsets:
                nx, ny = x + dx, y + dy
                if 0 <= nx < w and ny < h:
                    buffer[ny * w + nx] += err * (weight / divisor)

    return img_gray.convert("RGB").quantize(palette=pal_img, dither=Image.Dither.NONE)

# --- THREADS ---
class PreviewWorker(QThread):
    finished = Signal(object) 

    def __init__(self, parent=None):
        super().__init__(parent)
        self.img_proxy = None
        self.params = {}
        self.custom_cols = None

    def set_data(self, img_proxy, params, custom_cols):
        self.img_proxy = img_proxy
        self.params = params
        self.custom_cols = custom_cols

    def run(self):
        if not self.img_proxy:
            self.finished.emit(None)
            return
        
        try:
            work_img = self.img_proxy.copy()
            res = process_dithering(work_img, self.params, self.custom_cols)
            
            display_img = res.convert("RGBA")
            data = display_img.tobytes("raw", "RGBA")
            qim = QImage(data, display_img.width, display_img.height, QImage.Format_RGBA8888).copy()
            pix_res = QPixmap.fromImage(qim)
            
            self.finished.emit(pix_res)
        except Exception as e:
            print(f"Preview Error: {e}")
            self.finished.emit(None)

class BatchDitherWorker(QThread):
    progress = Signal(int, str)
    finished = Signal(int)
    error = Signal(str)
    
    def __init__(self, paths, out_dir, params, custom_cols, parent=None):
        super().__init__(parent)
        self.paths = paths
        self.out_dir = out_dir
        self.params = params
        self.custom_cols = custom_cols
        self._is_running = True

    def run(self):
        pal_name = self.params.get("palette", "1-Bit").split()[0]
        mode_name = self.params.get("mode", "Floyd").split()[0]
        suffix = f"{pal_name}_{mode_name}_{self.params.get('scale')}x"

        cnt = 0
        for i, p in enumerate(self.paths):
            if not self._is_running: break
            self.progress.emit(i, f"Processing {p.name}...")
            
            try:
                original_p = p 
                is_gif = p.suffix.lower() == ".gif"
                
                if is_gif:
                    with Image.open(p) as im:
                        frames = []
                        durations = []
                        
                        for idx, frame in enumerate(ImageSequence.Iterator(im)):
                            frame = frame.convert("RGBA")
                            frame_params = self.params.copy()
                            frame_params["frame_idx"] = idx
                            res = process_dithering(frame, frame_params, self.custom_cols)
                            frames.append(res)
                            durations.append(im.info.get('duration', 100))
                        
                        out_name = f"{original_p.stem}_dither_{suffix}.gif"
                        save_path = self.out_dir / out_name
                        
                        frames[0].save(
                            save_path,
                            save_all=True,
                            append_images=frames[1:],
                            duration=durations,
                            loop=0
                        )
                else:
                    with Image.open(p) as img:
                        img = ImageOps.exif_transpose(img)
                        
                        animate = self.params.get("animate_static", False)
                        anim_frames = self.params.get("anim_frames", 8)
                        anim_speed = self.params.get("anim_speed", 100)
                        
                        if animate:
                            frames = []
                            durations = []
                            for idx in range(anim_frames):
                                frame_copy = img.copy()
                                frame_params = self.params.copy()
                                frame_params["frame_idx"] = idx
                                res = process_dithering(frame_copy, frame_params, self.custom_cols)
                                frames.append(res)
                                durations.append(anim_speed)
                                
                            out_name = f"{original_p.stem}_dither_anim_{suffix}.gif"
                            save_path = self.out_dir / out_name
                            frames[0].save(
                                save_path,
                                save_all=True,
                                append_images=frames[1:],
                                duration=durations,
                                loop=0
                            )
                        else:
                            res = process_dithering(img, self.params, self.custom_cols)
                            out_name = f"{original_p.stem}_dither_{suffix}.png"
                            res.save(self.out_dir / out_name)
                
                cnt += 1
            except Exception as e:
                print(f"Error {p.name}: {e}")
        
        self.finished.emit(cnt)

    def stop(self):
        self._is_running = False

# --- MAIN TAB ---
class DitheringTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.meter = None
        self.image_paths = [] 
        self.path_map = {} 
        self.output_dir = None
        self.current_preview_path = None
        
        self.preview_proxy_img = None 
        self.loaded_proxy_path = ""

        self.custom_col_1 = [0, 0, 0]
        self.custom_col_2 = [255, 255, 255]
        
        self.preview_worker = PreviewWorker()
        self.preview_worker.finished.connect(self.on_preview_ready)
        
        self.debounce_timer = QTimer()
        self.debounce_timer.setSingleShot(True)
        self.debounce_timer.setInterval(200) 
        self.debounce_timer.timeout.connect(self.start_preview_worker)
        
